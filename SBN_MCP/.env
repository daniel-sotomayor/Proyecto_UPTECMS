# ============================================================
# Configuración de Ambiente - MySQL/XAMPP
# Sistema de Gestión de Bienes Nacionales
# ============================================================

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_bienes
DB_USER=root
DB_PASS=

# Aplicación
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=America/Caracas
# Generate a secure key: openssl rand -base64 32
APP_KEY=CHANGE_THIS_TO_SECURE_RANDOM_KEY_32_CHARS

# Seguridad
SESSION_LIFETIME=30
CSRF_TOKEN_LIFETIME=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Correo de contacto
MAIL_CONTACTO=bienes@mcp.gob.ve

# File upload limits
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,webp

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=3600
