# ============================================================
# Variables de Entorno — Sistema de Gestión de Bienes Nacionales
# Copiar este archivo como .env y completar los valores
# ============================================================

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_bienes
DB_USER=root
DB_PASS=admin

# Aplicación
APP_ENV=development        # development | production
APP_DEBUG=true             # true | false
APP_TIMEZONE=America/Caracas
APP_KEY=                   # Clave aleatoria de 32 chars (opcional)

# Seguridad de sesión
SESSION_LIFETIME=30        # Minutos de inactividad antes de expirar

# Correo de contacto (destino del formulario público)
MAIL_CONTACTO=bienes@mcp.gob.ve
